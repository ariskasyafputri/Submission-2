{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },

  "extends": [
    "airbnb-base",
    "plugin:cypress/recommended"
  ],

  "plugins": [
    "react",
    "cypress",
    "jest"
  ],

  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },

  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".jsx"]
      }
    }
  },

  "rules": {
    "no-console": "off",
    "no-unused-vars": ["error", { "varsIgnorePattern": "^[A-Z_]" }],
    "no-param-reassign": [
      "error",
      {
        "props": true,
        "ignorePropertyModificationsFor": ["state"]
      }
    ],
    "no-underscore-dangle": "off",
    "import/prefer-default-export": "off",
    "max-len": ["error", { "code": 185 }],
    "no-alert": "off",
    "consistent-return": "off",
    "import/no-unresolved": "off",

    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
        "vite.config.js",
        "eslint.config.js",
        "cypress.config.js",
        "jest.setup.js",
        "**/*.test.js",
        "**/*.test.jsx",
        "**/*.spec.js",
        "**/*.spec.jsx",
        "**/*.cy.js",
        "**/*.cy.jsx",
        "**/tests/**"
]

      }
    ]
  }
}
